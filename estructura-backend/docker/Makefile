# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
#  LUKA APP вҖ” Makefile
#  Comandos de gestiГіn del stack Docker.
#  Uso: make <comando>
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

.PHONY: help setup up down restart logs ps build rebuild clean nuke health \
        infra services tail-gateway tail-ia tail-financiero

# в”Җв”Җ Variables в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
COMPOSE         = docker compose
COMPOSE_PROD    = docker compose -f docker-compose.yml -f docker-compose.prod.yml
PROJECT         = luka-app

# Colores para la terminal
CYAN  = \033[0;36m
GREEN = \033[0;32m
YELLOW= \033[1;33m
RED   = \033[0;31m
NC    = \033[0m

# в”Җв”Җ AYUDA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
help:
	@echo ""
	@echo "$(CYAN)в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—$(NC)"
	@echo "$(CYAN)в•‘         LUKA APP вҖ” Comandos Docker           в•‘$(NC)"
	@echo "$(CYAN)в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ$(NC)"
	@echo ""
	@echo "$(GREEN)SETUP$(NC)"
	@echo "  make setup          вҶ’ Copia .env.example вҶ’ .env (primera vez)"
	@echo ""
	@echo "$(GREEN)CICLO DE VIDA$(NC)"
	@echo "  make up             вҶ’ Levanta todo el stack (modo detached)"
	@echo "  make infra          вҶ’ Levanta solo la infraestructura (BD + RabbitMQ + Eureka)"
	@echo "  make services       вҶ’ Levanta solo los microservicios (asume infra ya corriendo)"
	@echo "  make down           вҶ’ Detiene y elimina contenedores (conserva volГәmenes)"
	@echo "  make restart        вҶ’ down + up"
	@echo ""
	@echo "$(GREEN)BUILD$(NC)"
	@echo "  make build          вҶ’ Construye todas las imГЎgenes"
	@echo "  make rebuild        вҶ’ Reconstruye sin cachГ© (limpio total)"
	@echo ""
	@echo "$(GREEN)OBSERVABILIDAD$(NC)"
	@echo "  make ps             вҶ’ Estado de todos los contenedores"
	@echo "  make health         вҶ’ Healthcheck rГЎpido de todos los servicios"
	@echo "  make logs           вҶ’ Logs en tiempo real de todos los servicios"
	@echo "  make tail-gateway   вҶ’ Logs del API Gateway"
	@echo "  make tail-ia        вҶ’ Logs del Microservicio IA"
	@echo "  make tail-financieroвҶ’ Logs del NГәcleo Financiero"
	@echo ""
	@echo "$(RED)LIMPIEZA$(NC)"
	@echo "  make clean          вҶ’ Elimina contenedores + imГЎgenes del proyecto"
	@echo "  make nuke           вҶ’ Elimina TODO (contenedores + volГәmenes + imГЎgenes) вҡ пёҸ"
	@echo ""

# в”Җв”Җ SETUP INICIAL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
setup:
	@if [ ! -f .env ]; then \
		cp .env.example .env; \
		echo "$(GREEN)вң” .env creado desde .env.example$(NC)"; \
		echo "$(YELLOW)вҡ  IMPORTANTE: Edita .env y agrega tu GEMINI_API_KEY y JWT_SECRET_KEY$(NC)"; \
	else \
		echo "$(YELLOW)вҶ’ .env ya existe, no se sobreescribiГі$(NC)"; \
	fi

# в”Җв”Җ VERIFICAR .ENV в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
check-env:
	@if [ ! -f .env ]; then \
		echo "$(RED)вңҳ ERROR: No existe .env. Ejecuta: make setup$(NC)"; \
		exit 1; \
	fi
	@if grep -q "TU_GEMINI_API_KEY_AQUI" .env; then \
		echo "$(RED)вңҳ ERROR: Reemplaza GEMINI_API_KEY en .env con tu clave real$(NC)"; \
		exit 1; \
	fi
	@if grep -q "TU_JWT_SECRET_HEX_AQUI" .env; then \
		echo "$(RED)вңҳ ERROR: Reemplaza JWT_SECRET_KEY en .env$(NC)"; \
		exit 1; \
	fi
	@echo "$(GREEN)вң” .env verificado correctamente$(NC)"

# в”Җв”Җ CICLO DE VIDA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
up: check-env
	@echo "$(CYAN)в–¶ Levantando stack LUKA APP...$(NC)"
	$(COMPOSE) up -d
	@echo ""
	@echo "$(GREEN)вң” Stack iniciado$(NC)"
	@echo "  API Gateway     вҶ’ http://localhost:8080"
	@echo "  Eureka DashboardвҶ’ http://localhost:8761"
	@echo "  RabbitMQ UI     вҶ’ http://localhost:15672"
	@echo ""

infra: check-env
	@echo "$(CYAN)в–¶ Levantando infraestructura base...$(NC)"
	$(COMPOSE) up -d \
		postgres-usuario postgres-cliente postgres-financiero \
		postgres-auditoria postgres-mensajeria \
		rabbitmq eureka-server
	@echo "$(GREEN)вң” Infraestructura lista$(NC)"

services: check-env
	@echo "$(CYAN)в–¶ Levantando microservicios...$(NC)"
	$(COMPOSE) up -d \
		ms-usuario ms-cliente ms-auditoria \
		ms-mensajeria ms-nucleo-financiero ms-ia api-gateway
	@echo "$(GREEN)вң” Microservicios iniciados$(NC)"

down:
	@echo "$(YELLOW)в–  Deteniendo stack LUKA APP...$(NC)"
	$(COMPOSE) down
	@echo "$(GREEN)вң” Stack detenido$(NC)"

restart: down up

# в”Җв”Җ BUILD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
build: check-env
	@echo "$(CYAN)в–¶ Construyendo imГЎgenes...$(NC)"
	$(COMPOSE) build
	@echo "$(GREEN)вң” Build completado$(NC)"

rebuild: check-env
	@echo "$(CYAN)в–¶ Reconstruyendo imГЎgenes sin cachГ©...$(NC)"
	$(COMPOSE) build --no-cache
	@echo "$(GREEN)вң” Rebuild completado$(NC)"

# в”Җв”Җ OBSERVABILIDAD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ps:
	@echo "$(CYAN)Estado del stack LUKA APP:$(NC)"
	$(COMPOSE) ps

health:
	@echo "$(CYAN)Verificando healthchecks...$(NC)"
	@for svc in api-gateway eureka-server ms-usuario ms-cliente ms-auditoria ms-mensajeria ms-nucleo-financiero ms-ia; do \
		status=$$(docker inspect --format='{{.State.Health.Status}}' luka-$$svc 2>/dev/null || echo "not found"); \
		if [ "$$status" = "healthy" ]; then \
			echo "$(GREEN)  вң” $$svc вҶ’ $$status$(NC)"; \
		elif [ "$$status" = "not found" ]; then \
			echo "$(YELLOW)  ? $$svc вҶ’ no encontrado$(NC)"; \
		else \
			echo "$(RED)  вңҳ $$svc вҶ’ $$status$(NC)"; \
		fi; \
	done

logs:
	$(COMPOSE) logs -f --tail=50

tail-gateway:
	$(COMPOSE) logs -f --tail=100 api-gateway

tail-ia:
	$(COMPOSE) logs -f --tail=100 ms-ia

tail-financiero:
	$(COMPOSE) logs -f --tail=100 ms-nucleo-financiero

# в”Җв”Җ LIMPIEZA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clean: down
	@echo "$(YELLOW)в–  Eliminando imГЎgenes del proyecto...$(NC)"
	docker rmi $$(docker images "luka/*" -q) 2>/dev/null || true
	@echo "$(GREEN)вң” ImГЎgenes eliminadas$(NC)"

nuke:
	@echo "$(RED)вҡ  ATENCIГ“N: Esto elimina contenedores, volГәmenes e imГЎgenes$(NC)"
	@read -p "ВҝContinuar? (escribe 'si' para confirmar): " confirm; \
	if [ "$$confirm" = "si" ]; then \
		$(COMPOSE) down -v --rmi all --remove-orphans; \
		echo "$(GREEN)вң” Limpieza total completada$(NC)"; \
	else \
		echo "$(YELLOW)вҶ’ OperaciГіn cancelada$(NC)"; \
	fi