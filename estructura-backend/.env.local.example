# ═══════════════════════════════════════════════════════════════════════════════
#  LUKA APP — .env.local.example (PLANTILLA PARA DESARROLLO LOCAL)
# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES:
# Copia este archivo como '.env.local' en este mismo directorio y completa tus claves
# locales. No edites ni subas tus claves privadas a git.

# ── 🔐 1. VARIABLES COMPARTIDAS / SECRETOS COMUNES ────────────────────────────
# JWT (Seguridad)
JWT_SECRET_KEY=coloca_aqui_una_clave_secreta_jwt_de_64_caracteres_hexadecimales
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400000

# Base de Datos (PostgreSQL local en Host)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_contraseña_local
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=tu_contraseña_local

# Broker de Mensajería (RabbitMQ local en Host)
SPRING_RABBITMQ_HOST=host.docker.internal
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=/

# Caché local (Redis local en Host)
SPRING_DATA_REDIS_HOST=host.docker.internal
SPRING_DATA_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_DATA_REDIS_SSL_ENABLED=false
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ── 🐘 2. SECCIÓN BASES DE DATOS (Nombres de BDs en tu pgAdmin local) ─────────
DB_USUARIO_NAME=db_luka_usuario
DB_CLIENTE_NAME=db_luka_cliente
DB_AUDITORIA_NAME=db_luka_auditoria
DB_MENSAJERIA_NAME=db_luka_mensajeria
DB_FINANCIERO_NAME=db_luka_financiero
DB_IA_NAME=db_luka_ia
DB_PAGOS_NAME=db_luka_pagos

# ── 🤖 3. CONFIGURACIÓN ESPECÍFICA POR MICROSERVICIO ──────────────────────────

# [MICROSERVICIO IA]
GEMINI_API_KEY=tu_clave_api_gemini
GEMINI_MODELO=gemini-2.5-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURA=0.7
MESES_HISTORIAL=6
UMBRAL_GASTO_HORMIGA=30.0
UMBRAL_ANOMALIA=2.0

# [MICROSERVICIO MENSAJERÍA]
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_API_KEY_SID=tu_twilio_api_key_sid
TWILIO_API_KEY_SECRET=tu_twilio_api_key_secret
TWILIO_USE_API_KEY=true
TWILIO_SMS_FROM=tu_numero_twilio_sms
TWILIO_WHATSAPP_FROM=tu_numero_twilio_whatsapp
TWILIO_SANDBOX_WHATSAPP_FROM=tu_numero_sandbox_whatsapp
TWILIO_WHATSAPP_TEMPLATE_SID=tu_whatsapp_template_sid
TWILIO_MESSAGING_SERVICE_SID=tu_messaging_service_sid
SPRING_MAIL_USERNAME=tu_correo_gmail@gmail.com
SPRING_MAIL_PASSWORD=tu_clave_de_aplicacion_gmail

# [MICROSERVICIO PAGOS]
STRIPE_SECRET_KEY=tu_stripe_secret_key
STRIPE_WEBHOOK_SECRET=tu_stripe_webhook_secret
STRIPE_PRODUCT_PRO_ID=prod_UXcxMz1rEEfN0k
STRIPE_PRICE_PRO_ID=price_1TYXhuE4AqR3mWxPEqEN8HmA

# [MICROSERVICIO PAGOS — Mercado Pago]
MERCADOPAGO_ACCESS_TOKEN=MP_AT_...
MERCADOPAGO_WEBHOOK_SECRET=MP_WS_...

# ── 🌐 4. PUERTOS Y ROUTING LOCAL (Redirección dentro de la red Docker) ───────
GATEWAY_PORT=8080
PUERTO_USUARIO=8081
PUERTO_AUDITORIA=8082
PUERTO_CLIENTE=8083
PUERTO_MENSAJERIA=8084
PUERTO_NUCLEO_FINANCIERO=8085
PUERTO_IA=8086
PUERTO_PAGO=8087

FRONTEND_URL=http://localhost:4200

# Enlaces locales de comunicación inter-servicio
URL_PROD_USUARIO=http://ms-usuario:8081
URL_PROD_CLIENTE=http://ms-cliente:8083
URL_PROD_AUDITORIA=http://ms-auditoria:8082
URL_PROD_FINANCIERO=http://ms-nucleo-financiero:8085
URL_PROD_MENSAJERIA=http://ms-mensajeria:8084
URL_PROD_IA=http://ms-ia:8086
URL_PROD_PAGO=http://ms-pagos:8087
URL_PROD_GATEWAY=http://api-gateway:8080

# Token de seguridad interna para llamadas System-to-System (inter-servicio)
LUKA_INTERNAL_TOKEN=

