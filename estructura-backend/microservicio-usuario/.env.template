# ═══════════════════════════════════════════════════════════════════════════════
#  LUKA - MICROSERVICIO USUARIO (IAM) - PLANTILLA DE VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo con el nombre '.env' en este mismo directorio y completa los valores.
# ¡NUNCA subas el archivo '.env' real a GitHub con credenciales de producción!

# ── 🖥️ SERVIDOR ───────────────────────────────────────────────────────────────
SERVER_PORT=8081
SPRING_APPLICATION_NAME=microservicio-usuario

# ── 🐘 BASE DE DATOS (PostgreSQL) ──────────────────────────────────────────────
DB_HOST=tu_host_de_base_de_datos
DB_PORT=5432
DB_NAME=db_luka_usuario
DB_USER=tu_usuario_de_bd
DB_PASSWORD=tu_clave_de_bd

# ── 🚀 CACHÉ & RATE LIMIT (Redis) ──────────────────────────────────────────────
REDIS_HOST=tu_host_de_redis
REDIS_PORT=6379
REDIS_PASSWORD=tu_clave_de_redis

# ── 🐰 MENSAJERÍA ASÍNCRONA (RabbitMQ) ────────────────────────────────────────
RABBITMQ_HOST=tu_host_de_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=tu_usuario_de_rabbitmq
RABBITMQ_PASSWORD=tu_clave_de_rabbitmq

# ── 🛰️ GOBERNACIÓN (Eureka Discovery Server) ──────────────────────────────────
EUREKA_HOST=tu_host_de_eureka
EUREKA_PORT=8761
EUREKA_USER=tu_usuario_de_eureka
EUREKA_PASSWORD=tu_clave_de_eureka

# ── 🔐 SEGURIDAD (JWT) ────────────────────────────────────────────────────────
# Clave simétrica de 256 bits (o superior) firmada por HMAC
JWT_SECRET_KEY=tu_clave_secreta_jwt_de_desarrollo
JWT_EXPIRATION=86400000
